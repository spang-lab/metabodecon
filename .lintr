linters: linters_with_defaults(
    brace_linter = NULL,
    infix_spaces_linter = NULL,
    line_length_linter = line_length_linter(120),
    object_length_linter = object_length_linter(60),
    commented_code_linter = NULL,
    object_name_linter = NULL,
    indentation_linter = NULL,
    spaces_inside_linter = NULL,
    semicolon_linter = NULL
  )
exclusions: list(
    "vignettes/TODO/AKI_Classification.Rmd",
    "vignettes/TODO/AKI_Original.Rmd",
    "vignettes/TODO/Alignment_Details.md",
    "vignettes/TODO/Deconvolution_Details.md",
    "vignettes/TODO/NMR_Basics.md",
    "vignettes/TODO/PRARPX_vs_MSE.Rmd",
    "vignettes/TODO/Purpose.md",
    "vignettes/TODO/Urine_analysis.md",
    "R/MetaboDecon1D.R",
    "R/depr.R",
    "inst/akiwg/fkt_crossVal_SVM_AKI_urine_wg.R",
    "inst/akiwg/svm_radial_kernel_JH.R"
  )
